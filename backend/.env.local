# Backend environment variables — for local development only
# DO NOT commit this file to git

PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ppst_eportal?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=8h

# CORS
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
